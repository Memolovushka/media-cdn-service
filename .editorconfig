# https://editorconfig.org
# Mirrors the Biome formatter (see biome.jsonc) for non-VS-Code editors.
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 80

[*.md]
# Trailing whitespace is significant in Markdown (hard line breaks).
trim_trailing_whitespace = false
