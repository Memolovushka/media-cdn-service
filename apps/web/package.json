{
  "name": "web",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "portless",
    "dev:app": "next dev --turbopack",
    "build": "next build --turbopack",
    "deploy": "alchemy deploy --app web",
    "destroy": "alchemy destroy --app web",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply media-cdn-service-dev-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply media-cdn-service-dev-db --remote",
    "start": "next start",
    "typecheck": "tsc --noEmit"
  },
  "portless": {
    "name": "web",
    "script": "dev:app"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.6.19",
    "@opennextjs/cloudflare": "^1.19.11",
    "@orpc/server": "^1.13.5",
    "@workspace/api": "workspace:*",
    "@workspace/env": "workspace:*",
    "@workspace/ui": "workspace:*",
    "alchemy": "^0.93.12",
    "better-auth": "^1.6.19",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260617.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^25.1.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@workspace/typescript-config": "workspace:*",
    "babel-plugin-react-compiler": "^1.0.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.3",
    "wrangler": "^4.101.0"
  },
  "overrides": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3"
  }
}
